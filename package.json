{
  "name": "telegram-sticker-converter",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev:web": "npm run dev -w @sticker/web",
    "dev:worker": "npm run dev -w @sticker/worker",
    "test": "npm run test -w @sticker/core",
    "test:integration": "npm run test:integration -w @sticker/core",
    "build:core": "npm run build -w @sticker/core",
    "build": "npm run build -w @sticker/core && npm run build -w @sticker/web && npm run build -w @sticker/worker"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
